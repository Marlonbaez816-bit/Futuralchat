<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>FuturalChat</title>
    <style>
        body { margin: 0; background: #000; font-family: -apple-system, sans-serif; color: white; }
        .glass { 
            background: rgba(255, 255, 255, 0.1); 
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); 
            border-radius: 20px; padding: 20px; margin: 15px; border: 1px solid rgba(255,255,255,0.1); 
        }
        #chat-historial { height: 300px; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 12px; border-radius: 15px; max-width: 80%; font-size: 15px; }
        .mio { background: #007aff; align-self: flex-end; }
        .otro { background: rgba(255,255,255,0.2); align-self: flex-start; }
        .btn { background: #007aff; border: none; color: white; padding: 15px; border-radius: 15px; width: 100%; font-weight: bold; margin-bottom: 10px; }
        input { width: 100%; background: rgba(255,255,255,0.1); border: none; color: white; padding: 15px; border-radius: 15px; box-sizing: border-box; outline: none; }
    </style>
</head>
<body>

    <div class="glass">
        <h2 style="margin:0 0 10px 0;">ID: <span id="mi-id" style="color:#007aff">---</span></h2>
        <div style="display:flex; gap:10px;">
            <button class="btn" style="flex:1" onclick="iniciarLlamada()">Llamar</button>
            <button class="btn" style="background:#34c759; flex:1" onclick="pegarLlave()">Conectar</button>
        </div>
    </div>

    <div id="chat-historial"></div>

    <div class="glass" style="margin-top:0;">
        <input type="text" id="msj-input" placeholder="Escribe un mensaje...">
        <button class="btn" style="margin-top:10px" onclick="enviarMensaje()">Enviar 🚀</button>
        <button class="btn" style="background:#555" onclick="document.getElementById('f').click()">Subir Foto 📷</button>
        <input type="file" id="f" hidden accept="image/*" onchange="enviarFoto(this)">
    </div>

    <script>
        // Lógica corregida para evitar pantalla blanca
        let pc = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });
        let dc;

        // Generar ID
        if(!localStorage.getItem('myID')) localStorage.setItem('myID', Math.floor(10000 + Math.random() * 90000));
        document.getElementById('mi-id').innerText = localStorage.getItem('myID');

        function renderizar(txt, clase) {
            const h = document.getElementById('chat-historial');
            const d = document.createElement('div');
            d.className = 'msg ' + clase;
            d.innerText = txt;
            h.appendChild(d);
            h.scrollTop = h.scrollHeight;
        }

        async function iniciarLlamada() {
            dc = pc.createDataChannel("chat");
            dc.onmessage = e => renderizar(JSON.parse(e.data).v, 'otro');
            const offer = await pc.createOffer();
            await pc.setLocalDescription(offer);
            prompt("Copia y envía esta llave:", btoa(JSON.stringify(offer)));
        }

        async function pegarLlave() {
            const raw = prompt("Pega la llave aquí:");
            if(!raw) return;
            const data = JSON.parse(atob(raw));
            if(data.type === "offer") {
                await pc.setRemoteDescription(new RTCSessionDescription(data));
                const ans = await pc.createAnswer();
                await pc.setLocalDescription(ans);
                prompt("Envía esta respuesta de vuelta:", btoa(JSON.stringify(ans)));
            } else {
                await pc.setRemoteDescription(new RTCSessionDescription(data));
                alert("¡Conectado!");
            }
        }

        pc.ondatachannel = e => {
            dc = e.channel;
            dc.onmessage = ev => renderizar(JSON.parse(ev.data).v, 'otro');
        };

        function enviarMensaje() {
            const v = document.getElementById('msj-input').value;
            if(!v || !dc) return;
            dc.send(JSON.stringify({ v: v }));
            renderizar(v, 'mio');
            document.getElementById('msj-input').value = '';
        }
    </script>
</body>
</html>
