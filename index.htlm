<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <link rel="stylesheet" href="style.css">
    <link rel="manifest" href="manifest.json">
    <title>FuturChat</title>
</head>
<body>

    <!-- Pantalla de Perfil Personalizable -->
    <div id="app">
        <div class="perfil-config">
            <h2>Mi ID: <span id="mi-id">-----</span></h2>
            <input type="text" id="alias" placeholder="Tu Alias Futurista">
            <input type="file" id="foto-input" accept="image/*">
            <button onclick="guardarPerfil()">Guardar en Teléfono</button>
        </div>

        <!-- Botón para simular llamada (Prueba de Panel) -->
        <button onclick="mostrarLlamada('12345', 'Usuario X')">Simular Llamada Entrante</button>
    </div>

    <!-- Panel de Llamada (Oculto por defecto) -->
<!-- Dentro del panel-llamada -->
<div class="selector-calidad" style="margin-top: 15px;">
    <select id="calidad-video" onchange="actualizarCalidad(this.value)" style="background: rgba(255,255,255,0.2); color: white; border: none; padding: 5px 10px; border-radius: 10px; backdrop-filter: blur(10px);">
        <option value="144">Baja (144p)</option>
        <option value="360">Media (360p)</option>
        <option value="720" selected>HD (720p)</option>
    </select>
</div>

<!-- Elemento de Video donde se verá la otra persona -->
<video id="video-remoto" autoplay playsinline style="width: 90%; border-radius: 20px; margin-top: 10px; box-shadow: 0 0 30px rgba(255,255,255,0.1);"></video>
<!-- Tu propio video (miniatura) -->
<video id="video-local" autoplay playsinline muted style="width: 80px; height: 120px; position: absolute; bottom: 100px; right: 20px; border-radius: 10px; border: 2px solid white; object-fit: cover;"></video>

    <div id="panel-llamada" class="panel-llamada" style="display:none;">
        <img id="llamada-foto" src="" class="avatar-perfil">
        <h1 id="llamada-alias">Nombre</h1>
        <p>ID: <span id="llamada-id">00000</span></p>
        <div class="controles">
            <button onclick="cerrarLlamada()" style="background:red;">Colgar</button>
            <button style="background:green;">Responder</button>
        </div>
    </div>
<div class="controles-p2p" style="margin-top: 20px; padding: 10px; border-top: 1px solid #333;">
    <button onclick="iniciarLlamada()" style="background: #007aff;">Generar Llave de Llamada</button>
    <button onclick="procesarLlaveExterna()" style="background: #34c759;">Pegar Llave Recibida</button>
    
    <div id="chat-area" style="margin-top: 20px;">
        <input type="text" id="msj-input" placeholder="Escribe un mensaje...">
        <button onclick="enviarMensaje(document.getElementById('msj-input').value)">Enviar con Choque</button>
    </div>
</div>


    <script>
        // Generar ID de 5 dígitos si no existe
        if(!localStorage.getItem('myID')) {
            const nuevoID = Math.floor(10000 + Math.random() * 90000);
            localStorage.setItem('myID', nuevoID);
        }
        document.getElementById('mi-id').innerText = localStorage.getItem('myID');

        // Guardar foto localmente (IndexedDB simplificado)
        function guardarPerfil() {
            const alias = document.getElementById('alias').value;
            localStorage.setItem('alias', alias);
            alert("Datos guardados en tu " + (navigator.platform.includes('iPhone') ? 'iPhone' : 'Redmi'));
        }

        function mostrarLlamada(id, alias) {
            document.getElementById('llamada-id').innerText = id;
            document.getElementById('llamada-alias').innerText = alias;
            document.getElementById('panel-llamada').style.display = 'flex';
            // Efecto de vibración (Redmi)
            if(navigator.vibrate) navigator.vibrate([500, 200, 500]);
        }

        function cerrarLlamada() {
            document.getElementById('panel-llamada').style.display = 'none';
        }
    </script>
// Configuración de Servidores de Paso (Gratuitos de Google para saltar firewalls)
const configuration = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };
let peerConnection = new RTCPeerConnection(configuration);
let dataChannel;

// 1. CREAR CONEXIÓN (Para el que inicia la llamada)
async function iniciarLlamada() {
    dataChannel = peerConnection.createDataChannel("chat");
    configurarCanal(dataChannel);

    const offer = await peerConnection.createOffer();
    await peerConnection.setLocalDescription(offer);
    
    // Este código largo es tu "llave". Debes enviársela al otro teléfono.
    const llavePublica = btoa(JSON.stringify(offer));
    prompt("Copia esta llave y envíala a tu otro teléfono por SMS/WhatsApp:", llavePublica);
}

// 2. RECIBIR LLAMADA (Para el que acepta)
async function recibirLlamada(llaveRecibida) {
    const offer = JSON.parse(atob(llaveRecibida));
    await peerConnection.setRemoteDescription(new RTCSessionDescription(offer));
    
    const answer = await peerConnection.createAnswer();
    await peerConnection.setLocalDescription(answer);
    
    const respuestaLlave = btoa(JSON.stringify(answer));
    prompt("Copia esta RESPUESTA y envíala de vuelta al iPhone:", respuestaLlave);
}

// 3. CONECTAR FINALMENTE
async function finalizarConexion(respuestaRecibida) {
    const answer = JSON.parse(atob(respuestaRecibida));
    await peerConnection.setRemoteDescription(new RTCSessionDescription(answer));
    alert("¡Conexión Segura Establecida! Ya pueden hablar.");
}

// Configuración de los eventos del canal de datos
function configurarCanal(channel) {
    channel.onopen = () => console.log("Canal Abierto");
    channel.onmessage = (e) => {
        const datos = JSON.parse(e.data);
        mostrarChoqueMensaje(datos.texto, datos.alias);
    };
}

// Escuchar cuando el otro abre el canal
peerConnection.ondatachannel = (event) => {
    dataChannel = event.channel;
    configurarCanal(dataChannel);
};

// FUNCIÓN PARA ENVIAR FOTOS/MENSAJES
function enviarMensaje(texto) {
    const payload = {
        texto: texto,
        alias: localStorage.getItem('alias') || "Anónimo",
        id: localStorage.getItem('myID')
    };
    dataChannel.send(JSON.stringify(payload));
}

</body>
</html>
