<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>FuturalChat</title>
    <style>
        /* ESTILOS FUTURISTAS Y DESENFOQUES */
        body { margin: 0; background: #000; font-family: -apple-system, sans-serif; color: white; overflow-x: hidden; }
        .glass { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 20px; margin: 10px; }
        
        /* PANEL DE LLAMADA ESTILO IPHONE */
        #panel-llamada { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.8); backdrop-filter: blur(30px); display: none; flex-direction: column; align-items: center; justify-content: center; z-index: 9999; animation: entrada 0.5s ease; }
        @keyframes entrada { from { transform: scale(1.2); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        
        .btn { padding: 15px; border-radius: 15px; border: none; color: white; font-weight: bold; cursor: pointer; width: 100%; margin: 5px 0; }
        .btn-blue { background: #007aff; } .btn-red { background: #ff3b30; } .btn-green { background: #34c759; }

        /* PREVISUALIZACIÓN GLOBAL */
        .preview { position: fixed; top: 20px; left: 5%; width: 90%; background: rgba(255,255,255,0.15); backdrop-filter: blur(15px); border-radius: 15px; padding: 15px; z-index: 10000; display: none; animation: choque 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes choque { 0% { transform: translateY(-100px); } 70% { transform: translateY(10px); } 100% { transform: translateY(0); } }

        video { width: 100%; border-radius: 15px; background: #222; margin-top: 10px; }
    </style>
</head>
<body>

    <!-- NOTIFICACIÓN DE CHOQUE (PREVIEW) -->
    <div id="notificacion" class="preview">
        <b id="nt-alias">Usuario</b>
        <p id="nt-msg">Mensaje entrante...</p>
    </div>

    <div class="glass">
        <h2>Mi ID: <span id="mi-id" style="color:#007aff">-----</span></h2>
        <input type="text" id="alias" placeholder="Tu Alias" style="width:90%; padding:10px; border-radius:10px; border:none; margin-bottom:10px;">
        <button class="btn btn-blue" onclick="guardarPerfil()">Guardar en Teléfono</button>
    </div>

    <div class="glass">
        <button class="btn btn-blue" onclick="iniciarLlamada()">Generar Llave de Conexión</button>
        <button class="btn btn-green" onclick="pegarLlave()">Pegar Llave Recibida</button>
        <hr style="opacity:0.2">
        <input type="text" id="msj-input" placeholder="Escribe algo..." style="width:70%; padding:10px; border-radius:10px; border:none;">
        <button onclick="enviarMensaje()" style="padding:10px; border-radius:10px; border:none; background:#555; color:white;">Enviar</button>
        
        <div style="margin-top:15px; text-align:center;">
            <button id="btn-voz" onclick="toggleVoz()" style="background:#ff3b30; border-radius:50%; width:60px; height:60px; border:none; font-size:24px;">🎤</button>
            <p id="voz-status" style="font-size:12px; color:#888;">Mensaje de Voz</p>
        </div>
    </div>

    <!-- PANEL DE LLAMADA FUTURISTA -->
    <div id="panel-llamada">
        <div style="width:120px; height:120px; border-radius:50%; background:#333; margin-bottom:20px;" id="foto-circulo"></div>
        <h1 id="ll-alias">Llamando...</h1>
        <p id="ll-id">ID: 00000</p>
        
        <select id="calidad" onchange="cambiarCalidad(this.value)" style="background:#222; color:white; padding:10px; border-radius:10px; margin-bottom:10px;">
            <option value="144">144p (Bajo)</option>
            <option value="360" selected>360p (Medio)</option>
            <option value="720">720p (HD)</option>
        </select>

        <video id="v-remoto" autoplay playsinline></video>
        
        <div style="display:flex; gap:10px; width:80%; margin-top:20px;">
            <button class="btn btn-red" onclick="cerrarLlamada()">Colgar</button>
            <button class="btn btn-green">Responder</button>
        </div>
    </div>

    <script>
        // --- IDENTIFICADOR ---
        if(!localStorage.getItem('myID')) {
            localStorage.setItem('myID', Math.floor(10000 + Math.random() * 90000));
        }
        document.getElementById('mi-id').innerText = localStorage.getItem('myID');

        function guardarPerfil() {
            localStorage.setItem('alias', document.getElementById('alias').value);
            alert("Perfil guardado localmente");
        }

        // --- PREVISUALIZACIÓN DE CHOQUE ---
        function mostrarChoque(alias, msg) {
            document.getElementById('nt-alias').innerText = alias;
            document.getElementById('nt-msg').innerText = msg;
            const nt = document.getElementById('notificacion');
            nt.style.display = 'block';
            if(navigator.vibrate) navigator.vibrate([100, 50, 100]); // Efecto choque
            setTimeout(() => { nt.style.display = 'none'; }, 4000);
        }

        // --- LLAMADA Y CALIDAD ---
        function iniciarLlamada() {
            document.getElementById('panel-llamada').style.display = 'flex';
            // Aquí iría la lógica de WebRTC que te pasé antes
            const dummyLlave = btoa("oferta-p2p-" + localStorage.getItem('myID'));
            prompt("Copia esta llave y pásala a tu contacto:", dummyLlave);
        }

        function pegarLlave() {
            const llave = prompt("Pega la llave aquí:");
            if(llave) mostrarChoque("Sistema", "Conectando P2P...");
        }

        function cerrarLlamada() {
            document.getElementById('panel-llamada').style.display = 'none';
        }

        function cambiarCalidad(res) {
            alert("Cambiando calidad a " + res + "p...");
            // Aquí se ajustan los constraints de la cámara
        }

        // --- MENSAJES DE VOZ ---
        let recorder;
        let chunks = [];
        async function toggleVoz() {
            const btn = document.getElementById('btn-voz');
            if(!recorder || recorder.state === 'inactive') {
                const s = await navigator.mediaDevices.getUserMedia({audio:true});
                recorder = new MediaRecorder(s);
                recorder.ondataavailable = e => chunks.push(e.data);
                recorder.onstop = () => {
                    alert("Audio guardado en el teléfono");
                    mostrarChoque("Tú", "🎤 Audio enviado");
                };
                chunks = [];
                recorder.start();
                btn.style.background = "#34c759";
            } else {
                recorder.stop();
                btn.style.background = "#ff3b30";
            }
        }
    </script>
</body>
</html>
